#Область ПрограммныйИнтерфейс

// Рассчитывает сумму строки табличной части.
// Параметры:
//   Количество - Число - количество единиц
//   Цена       - Число - цена за единицу
// Возвращаемое значение:
//   Число - рассчитанная сумма строки
Функция РассчитатьСуммуСтроки(Количество, Цена) Экспорт
	Возврат Количество * Цена;
КонецФункции

// Проверяет заполнение обязательных реквизитов объекта.
// Параметры:
//   Реквизиты - Массив - массив структур с полями Значение и Наименование
//   Отказ     - Булево - флаг отказа (устанавливается в Истина при ошибке)
Процедура ПроверитьЗаполнениеРеквизитов(Реквизиты, Отказ) Экспорт
	
	Для Каждого Реквизит Из Реквизиты Цикл
		Если НЕ ЗначениеЗаполнено(Реквизит.Значение) Тогда
			ТекстСообщения = СтрШаблон("Не заполнено обязательное поле ""%1""", Реквизит.Наименование);
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Поле = Реквизит.Наименование;
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Получает актуальную цену услуги из регистра сведений ЦеныУслуг.
// Параметры:
//   Услуга - СправочникСсылка.Услуги - ссылка на услугу
//   Дата   - Дата - дата, на которую нужно получить цену
// Возвращаемое значение:
//   Число - актуальная цена услуги или 0, если цена не найдена
Функция ПолучитьЦенуУслуги(Услуга, Дата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЦеныУслугСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныУслуг.СрезПоследних(&Дата, Услуга = &Услуга) КАК ЦеныУслугСрезПоследних";
	
	Запрос.УстановитьПараметр("Услуга", Услуга);
	Запрос.УстановитьПараметр("Дата", Дата);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат 0;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Цена;
	
КонецФункции

// Проверяет достаточность остатка материала на складе.
// Параметры:
//   Материал   - СправочникСсылка.Материалы - ссылка на материал
//   Количество - Число - требуемое количество
// Возвращаемое значение:
//   Булево - Истина, если остаток достаточен; Ложь — если нет
Функция ПроверитьОстатокМатериала(Материал, Количество) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(ОстаткиМатериаловОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ИЗ
		|	РегистрНакопления.ОстаткиМатериалов.Остатки(, Материал = &Материал) КАК ОстаткиМатериаловОстатки";
	
	Запрос.УстановитьПараметр("Материал", Материал);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоОстаток >= Количество;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

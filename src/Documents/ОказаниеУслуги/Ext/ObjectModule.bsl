#Область ОбработчикиСобытий

// Процедура проведения документа «Оказание услуги».
// Формирует движения в регистрах накопления:
//   - «Выручка» — фиксирует факт реализации услуг
//   - «ОстаткиМатериалов» — списывает расходные материалы
// Перед списанием проверяет достаточность остатков материалов.
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// --- Проверка обязательных реквизитов ---
	Если НЕ ЗначениеЗаполнено(Клиент) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен реквизит ""Клиент""";
		Сообщение.Поле  = "Клиент";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если Услуги.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Табличная часть ""Услуги"" не заполнена";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// --- Получаем все необходимые данные одним запросом,
	//     чтобы избежать запросов в цикле ---
	
	// Формируем список материалов из табличной части для передачи в запрос
	ТаблицаМатериалов = Новый ТаблицаЗначений;
	ТаблицаМатериалов.Колонки.Добавить("Материал");
	ТаблицаМатериалов.Колонки.Добавить("Количество");
	
	Для Каждого СтрокаМатериала Из Материалы Цикл
		Если ЗначениеЗаполнено(СтрокаМатериала.Материал) Тогда
			НоваяСтрока = ТаблицаМатериалов.Добавить();
			НоваяСтрока.Материал   = СтрокаМатериала.Материал;
			НоваяСтрока.Количество = СтрокаМатериала.Количество;
		КонецЕсли;
	КонецЦикла;
	
	// Запрос остатков по всем необходимым материалам за один раз
	Если ТаблицаМатериалов.Количество() > 0 Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|	ТаблицаМатериалов.Материал          КАК Материал,
			|	ТаблицаМатериалов.Количество        КАК КоличествоТребуется,
			|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК КоличествоОстаток
			|ИЗ
			|	&ТаблицаМатериалов КАК ТаблицаМатериалов
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиМатериалов.Остатки(
			|				,
			|				Материал В (ВЫБРАТЬ ТМ.Материал ИЗ &ТаблицаМатериалов КАК ТМ)
			|			) КАК Остатки
			|		ПО ТаблицаМатериалов.Материал = Остатки.Материал";
		
		Запрос.УстановитьПараметр("ТаблицаМатериалов", ТаблицаМатериалов);
		
		// Устанавливаем управляемую блокировку для корректной работы при параллельном проведении
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрНакопления.ОстаткиМатериалов");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		
		// Открываем транзакцию до установки блокировки
		НачатьТранзакцию();
		
		Попытка
			
			// Устанавливаем блокировку внутри транзакции
			БлокировкаДанных.Заблокировать();
			
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();
			
			// Проверяем достаточность остатков по каждому материалу
			Пока Выборка.Следующий() Цикл
				Если Выборка.КоличествоОстаток < Выборка.КоличествоТребуется Тогда
					ТекстОшибки = СтрШаблон(
						"Недостаточно материала ""%1"": требуется %2, доступно %3",
						Выборка.Материал,
						Выборка.КоличествоТребуется,
						Выборка.КоличествоОстаток
					);
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = ТекстОшибки;
					Сообщение.Сообщить();
					Отказ = Истина;
				КонецЕсли;
			КонецЦикла;
			
			Если Отказ Тогда
				ОтменитьТранзакцию();
				Возврат;
			КонецЕсли;
			
			// --- Формируем движения в регистре «Выручка» ---
			ЗаписатьДвиженияВыручки(Ссылка, Дата, Клиент, Сотрудник, Услуги);
			
			// --- Формируем движения в регистре «ОстаткиМатериалов» ---
			НаборМатериалы = РегистрыНакопления.ОстаткиМатериалов.СоздатьНаборЗаписей();
			НаборМатериалы.Отбор.Регистратор.Установить(Ссылка);
			НаборМатериалы.Прочитать();
			НаборМатериалы.Очистить();
			
			Для Каждого СтрокаМатериала Из Материалы Цикл
				Если НЕ ЗначениеЗаполнено(СтрокаМатериала.Материал) Тогда
					Продолжить;
				КонецЕсли;
				// Расход материала — вид движения «Расход»
				ЗаписьМатериал = НаборМатериалы.Добавить();
				ЗаписьМатериал.ВидДвижения = ВидДвиженияНакопления.Расход;
				ЗаписьМатериал.Период      = Дата;
				ЗаписьМатериал.Материал    = СтрокаМатериала.Материал;
				ЗаписьМатериал.Количество  = СтрокаМатериала.Количество;
			КонецЦикла;
			
			НаборМатериалы.Записать();
			
			// Фиксируем транзакцию после успешной записи всех движений
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			// Откатываем транзакцию и сообщаем об ошибке
			ОтменитьТранзакцию();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при проведении документа: " + ОписаниеОшибки();
			Сообщение.Сообщить();
			Отказ = Истина;
			
		КонецПопытки;
		
	Иначе
		
		// Нет материалов — записываем только выручку
		НачатьТранзакцию();
		
		Попытка
			
			ЗаписатьДвиженияВыручки(Ссылка, Дата, Клиент, Сотрудник, Услуги);
			ЗафиксироватьТранзакцию();
			
		Исключение
			ОтменитьТранзакцию();
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при проведении документа: " + ОписаниеОшибки();
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

// Вспомогательная процедура записи движений в регистр накопления «Выручка».
// Параметры:
//   Регистратор - ДокументСсылка - ссылка на документ-регистратор
//   ДатаДок     - Дата           - дата документа
//   КлиентДок   - СправочникСсылка.Клиенты   - клиент
//   СотрудникДок- СправочникСсылка.Сотрудники - сотрудник
//   ТЧУслуги    - ТабличнаяЧасть - табличная часть «Услуги» документа
Процедура ЗаписатьДвиженияВыручки(Регистратор, ДатаДок, КлиентДок, СотрудникДок, ТЧУслуги)
	
	НаборВыручка = РегистрыНакопления.Выручка.СоздатьНаборЗаписей();
	НаборВыручка.Отбор.Регистратор.Установить(Регистратор);
	НаборВыручка.Прочитать();
	НаборВыручка.Очистить();
	
	Для Каждого СтрокаУслуги Из ТЧУслуги Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаУслуги.Услуга) Тогда
			Продолжить;
		КонецЕсли;
		ЗаписьВыручка = НаборВыручка.Добавить();
		ЗаписьВыручка.ВидДвижения = ВидДвиженияНакопления.Приход;
		ЗаписьВыручка.Период      = ДатаДок;
		ЗаписьВыручка.Услуга      = СтрокаУслуги.Услуга;
		ЗаписьВыручка.Клиент      = КлиентДок;
		ЗаписьВыручка.Сотрудник   = СотрудникДок;
		ЗаписьВыручка.Сумма       = СтрокаУслуги.Сумма;
		ЗаписьВыручка.Количество  = СтрокаУслуги.Количество;
	КонецЦикла;
	
	НаборВыручка.Записать();
	
КонецПроцедуры

#КонецОбласти

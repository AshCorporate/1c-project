#Область ОбработчикиСобытий

// Процедура проведения документа «Поступление материалов».
// Формирует приходные движения в регистре накопления «ОстаткиМатериалов».
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Проверка заполнения табличной части
	Если Материалы.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Табличная часть ""Материалы"" не заполнена";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Открываем транзакцию для атомарной записи движений
	НачатьТранзакцию();
	
	Попытка
		
		// Получаем набор записей регистра «ОстаткиМатериалов»
		НаборЗаписей = РегистрыНакопления.ОстаткиМатериалов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить();
		
		// Создаём приходные движения по каждому материалу
		Для Каждого СтрокаМатериала Из Материалы Цикл
			
			Если НЕ ЗначениеЗаполнено(СтрокаМатериала.Материал) Тогда
				Продолжить;
			КонецЕсли;
			
			// Вид движения — «Приход» (увеличение остатка)
			ЗаписьДвижения = НаборЗаписей.Добавить();
			ЗаписьДвижения.ВидДвижения = ВидДвиженияНакопления.Приход;
			ЗаписьДвижения.Период      = Дата;
			ЗаписьДвижения.Материал    = СтрокаМатериала.Материал;
			ЗаписьДвижения.Количество  = СтрокаМатериала.Количество;
			
		КонецЦикла;
		
		// Записываем набор движений
		НаборЗаписей.Записать();
		
		// Фиксируем транзакцию
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		// Откатываем транзакцию при ошибке
		ОтменитьТранзакцию();
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при проведении документа: " + ОписаниеОшибки();
		Сообщение.Сообщить();
		Отказ = Истина;
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

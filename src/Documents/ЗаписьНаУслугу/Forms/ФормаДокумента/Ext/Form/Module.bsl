#Область ОбработчикиСобытийФормы

// Обработчик события формы «ПриСозданииНаСервере».
// Устанавливает начальные значения реквизитов формы.
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Устанавливаем статус «Новая» для нового документа
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Статус = Перечисления.СтатусыЗаписей.Новая;
		Объект.ДатаЗаписи = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийТабличнойЧасти

// Обработчик изменения реквизита «Услуга» в строке табличной части.
// При выборе услуги автоматически подставляет актуальную цену из регистра сведений.
&НаКлиенте
Процедура УслугиУслугаПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы.Услуги.ТекущиеДанные;
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем цену с сервера и заполняем строку
	ЗаполнитьЦенуНаСервере(СтрокаТЧ.НомерСтроки);
	
КонецПроцедуры

// Обработчик изменения реквизита «Количество» в строке табличной части.
// Пересчитывает сумму строки.
&НаКлиенте
Процедура УслугиКоличествоПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы.Услуги.ТекущиеДанные;
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Пересчитываем сумму = Количество * Цена
	СтрокаТЧ.Сумма = СтрокаТЧ.Количество * СтрокаТЧ.Цена;
	
КонецПроцедуры

// Обработчик изменения реквизита «Цена» в строке табличной части.
// Пересчитывает сумму строки.
&НаКлиенте
Процедура УслугиЦенаПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы.Услуги.ТекущиеДанные;
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Пересчитываем сумму = Количество * Цена
	СтрокаТЧ.Сумма = СтрокаТЧ.Количество * СтрокаТЧ.Цена;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура получает цену услуги с сервера и подставляет её в строку ТЧ.
// Параметры:
//   НомерСтроки - Число - номер строки табличной части «Услуги»
&НаСервере
Процедура ЗаполнитьЦенуНаСервере(НомерСтроки)
	
	СтрокаТЧ = Объект.Услуги.НайтиПоНомеруСтроки(НомерСтроки);
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Услуга) Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем актуальную цену через общий модуль сервера
	ДатаДокумента = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата());
	Цена = ОбщийМодульСервер.ПолучитьЦенуУслуги(СтрокаТЧ.Услуга, ДатаДокумента);
	
	СтрокаТЧ.Цена  = Цена;
	СтрокаТЧ.Сумма = СтрокаТЧ.Количество * Цена;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

// Процедура проведения документа «Запись на услугу».
// Формирует плановые движения в регистре накопления «Выручка».
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Проверка обязательных реквизитов шапки
	Если НЕ ЗначениеЗаполнено(Клиент) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен реквизит ""Клиент""";
		Сообщение.Поле = "Клиент";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если Услуги.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Табличная часть ""Услуги"" не заполнена";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Открываем транзакцию для атомарной записи движений
	НачатьТранзакцию();
	
	Попытка
		
		// Получаем набор записей регистра накопления «Выручка»
		НаборЗаписей = РегистрыНакопления.Выручка.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить();
		
		// Формируем движения по каждой строке табличной части «Услуги»
		Для Каждого СтрокаУслуги Из Услуги Цикл
			
			Если НЕ ЗначениеЗаполнено(СтрокаУслуги.Услуга) Тогда
				Продолжить;
			КонецЕсли;
			
			// Создаём запись движения (приход выручки)
			ЗаписьДвижения = НаборЗаписей.Добавить();
			ЗаписьДвижения.ВидДвижения = ВидДвиженияНакопления.Приход;
			ЗаписьДвижения.Период      = Дата;
			ЗаписьДвижения.Услуга      = СтрокаУслуги.Услуга;
			ЗаписьДвижения.Клиент      = Клиент;
			ЗаписьДвижения.Сотрудник   = Сотрудник;
			ЗаписьДвижения.Сумма       = СтрокаУслуги.Сумма;
			ЗаписьДвижения.Количество  = СтрокаУслуги.Количество;
			
		КонецЦикла;
		
		// Записываем набор движений
		НаборЗаписей.Записать();
		
		// Фиксируем транзакцию
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		// Откатываем транзакцию при ошибке
		ОтменитьТранзакцию();
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при проведении документа: " + ОписаниеОшибки();
		Сообщение.Сообщить();
		Отказ = Истина;
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

// Процедура выполняется перед записью объекта.
// Проверяет заполнение наименования услуги.
Процедура ПередЗаписью(Отказ)
	
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнено обязательное поле ""Наименование""";
		Сообщение.Поле = "Наименование";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
